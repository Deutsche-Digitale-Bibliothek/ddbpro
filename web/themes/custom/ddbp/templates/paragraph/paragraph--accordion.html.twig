{% set imageField = content.field_image[0]|default(null) %}
{% set headlineText = content.field_headline[0]['#context'].value|default('') %}
{% set accordion = {
  type: 'paragraph',
  image: imageField,
  title: headlineText,
  text: content.field_paragraphs,
} %}

{% include '@ddbp/partials/accordion.html.twig' with accordion %}
