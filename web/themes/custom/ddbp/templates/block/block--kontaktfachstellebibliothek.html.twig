{% set linkField = content.field_link[0]|default(null) %}
{% set link = {
  url: linkField ? linkField['#url'] : '',
  text: linkField ? linkField['#title'] : '',
  type: 'primary',
} %}
{% set hasLink = link.url and link.text %}

<div class="service-contact">
  <div class="service-contact__description">
    {{ content.field_description }}
  </div>
  {% if hasLink %}
    <div class="service-contact__link">
      {% include '@ddbp/partials/link-button.html.twig' with link %}
    </div>
  {% endif %}
</div>
