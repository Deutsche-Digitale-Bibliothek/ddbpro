{% set bundle = node.bundle|clean_class %}

{% set classes = [
  'node',
  'node--' ~ bundle,
  'search-teaser',
] %}

{% set type_mapping = {
  'faq': 'FAQ',
  'event': 'Termine & Veranstaltungen',
  'aggregator_portrait': 'Aggregatoren',
  'aggregator-portrait': 'Aggregatoren',
  'department': 'Fachstellen',
  'glossary_term': 'Glossar',
  'glossary-term': 'Glossar'
} %}

{% set type = type_mapping[bundle] ?? 'Inhalt' %}

{% set teaserText = content.field_teaser_text[0]['#context'].value|default('')|striptags|raw|trim %}
{% set answerText = content.field_answer|render|striptags|raw|trim %}
{% set bodyText = content.body|render|striptags|raw|trim %}
{% set descriptionText = content.field_description|render|striptags|raw|trim %}
{% set hasText = teaserText or answerText or bodyText or descriptionText %}

<article{{ attributes.addClass(classes).removeAttribute('role') }}>
  <div class="search-teaser__type">
    {{ type | t }}
  </div>
  <a href="{{ url }}" class="search-teaser__title">
    <h2 class="h4">
      {{ label[0]['#context'].value|default('') }}
    </h2>
  </a>
  {% if hasText %}
    <a href="{{ url }}" class="search-teaser__description text-formatted" tabindex="-1">
      {% if teaserText %}
        <p class="search-teaser__description__teaser">{{ bundle == 'event' ? teaserText : teaserText|truncate(400, true, '...') }}</p>
      {% endif %}
      {% if answerText %}
        <p>{{ answerText|truncate(400, true, '...') }}</p>
      {% endif %}
      {% if bodyText %}
        <p>{{ bodyText|truncate(400, true, '...') }}</p>
      {% endif %}
      {% if descriptionText %}
        <p>{{ descriptionText|truncate(400, true, '...')|raw }}</p>
      {% endif %}
    </a>
  {% endif %}
  <div class="search-teaser__link">
    <a href="{{ url }}" tabindex="-1">
      {{ url('entity.node.canonical', { 'node': node.id }) }}
    </a>
  </div>
</article>
