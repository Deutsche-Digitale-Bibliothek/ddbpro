{% set classes = [
  'front-page',
] %}

{% set latestEvents = get_latest_events() %}
{% set announcementLinkField = content.field_announcement_link[0]|default(null) %}
{% set announcementLink = {
  url: announcementLinkField ? announcementLinkField['#url'] : '',
  attributes: announcementLinkField ? announcementLinkField['#url'].getOptions()['attributes'] : {},
  target: announcementLinkField ? announcementLinkField['#options']['attributes']['target'] == '_blank' : false,
} %}
{% set announcementText = {
  title: content.field_announcement_title[0]['#context'].value|default(''),
  description: content.field_announcement_description[0]['#context'].value|default(''),
} %}

<div{{ attributes.addClass(classes) }}>
  <a id="main-content" tabindex="-1" class="visually-hidden"></a>
  {# announcement #}
  {% if content.field_show_announcement[0]['#markup']|default('') == 'Yes' %}
    <div class="container">
      <div class="announcement">
        {% if announcementLink.url %}
          <a href="{{ announcementLink.url }}"
            {% for key, value in announcementLink.attributes %}{{ key }}="{{ value }}" {% endfor %}
            class="announcement__link">
            {% if announcementText.title or announcementText.description %}
              <div class="announcement__text-wrapper">
                <div>
                  <div class="announcement__text">
                    <p>
                      <span>{{ announcementText.title }}</span>
                      {{ announcementText.description }}
                    </p>
                  </div>
                  <div class="announcement__text">
                    <p>
                      <span>{{ announcementText.title }}</span>
                      {{ announcementText.description }}
                    </p>
                  </div>
                </div>
              </div>
            {% endif %}

            <div class="announcement__more">
              <i class="fa-solid fa-arrow-right"></i>
            </div>
          </a>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {# hero #}
  <div class="hero">
    <div class="hero__gallery">
      <div class="gallery__row">
        <div class="gallery__column">
          {% set gallery = content.field_gallery_column_1 %}
          {% for key, image in gallery %}
            {% if key matches '/^\\d+$/' %}
              {% set responsiveImage = { images: image.images } %}
              <div class="grid__column-image">
                {% include '@ddbp/partials/responsive-image.html.twig' with responsiveImage %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="gallery__column">
          {% set gallery = content.field_gallery_column_2 %}
          {% for key, image in gallery %}
            {% if key matches '/^\\d+$/' %}
              {% set responsiveImage = { images: image.images } %}
              <div class="grid__column-image">
                {% include '@ddbp/partials/responsive-image.html.twig' with responsiveImage %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="gallery__column">
          {% set gallery = content.field_gallery_column_3 %}
          {% for key, image in gallery %}
            {% if key matches '/^\\d+$/' %}
              {% set responsiveImage = { images: image.images } %}
              <div class="grid__column-image">
                {% include '@ddbp/partials/responsive-image.html.twig' with responsiveImage %}
              </div>
            {%endif %}
          {% endfor %}
        </div>
        <div class="gallery__column">
          {% set gallery = content.field_gallery_column_4 %}
          {% for key, image in gallery %}
            {% if key matches '/^\\d+$/' %}
              {% set responsiveImage = { images: image.images } %}
              <div class="grid__column-image">
                {% include '@ddbp/partials/responsive-image.html.twig' with responsiveImage %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="container">
      {# block on the top left #}
      <div class="hero__content-top">
        <div class="row">
          <div class="column">
            <h1>{{ content.field_headline[0]['#context'].value|default('') }}</h1>
            <p class="h3">
              {{ content.field_subheadline[0]['#context'].value|default('') }}
            </p>
            {% set linkTitleField = content.field_title_cta[0]|default(null) %}
            {% set linkTitle = {
              url: linkTitleField ? linkTitleField['#url'] : '',
              text: linkTitleField ? linkTitleField['#title'] : '',
              type: 'primary',
              target: linkTitleField ? linkTitleField['#options']['attributes']['target'] : '',
            } %}
            {% if linkTitleField %}
              {% include '@ddbp/partials/link-button.html.twig' with { link: linkTitle } %}
            {% endif %}
          </div>
        </div>
      </div>

      {# Block on the bottom right. #}
      {# Participation data object. #}
      {% set participationData = {
        headline: config_pages.field_participation_headline.value,
        description: content.field_participation_description,
        steps: config_pages.field_participation_steps,
        linkPrimary: {
          url: (content.field_participation_cta_left[0]|default(null)) ? content.field_participation_cta_left[0]['#url'] : '',
          text: (content.field_participation_cta_left[0]|default(null)) ? content.field_participation_cta_left[0]['#title'] : '',
          type: 'primary',
          target: (content.field_participation_cta_left[0]|default(null)) ? content.field_participation_cta_left[0]['#options']['attributes']['target'] : '',
          'aria-describedby': 'frontpage-participate-now',
        },
        linkSecondary: {
          url: (content.field_participation_cta_right[0]|default(null)) ? content.field_participation_cta_right[0]['#url'] : '',
          text: (content.field_participation_cta_right[0]|default(null)) ? content.field_participation_cta_right[0]['#title'] : '',
          type: 'secondary',
          bg: 'light',
          target: (content.field_participation_cta_right[0]|default(null)) ? content.field_participation_cta_right[0]['#options']['attributes']['target'] : '',
          'aria-describedby': 'frontpage-details-flow-chart',
        },
      } %}

      <div class="hero__content-bottom">
        <div class="row">
          <div class="column">
            {% include '@ddbp/partials/participation.html.twig' with { data: participationData } %}
          </div>
        </div>
      </div>
    </div>
  </div>

  {# DDB studio #}
  {% set studioCTALeftField = content.field_studio_cta_left[0]|default(null) %}
  {% set studioCTARightField = content.field_studio_cta_right[0]|default(null) %}
  {% set linkPrimary = {
    url: studioCTALeftField ? studioCTALeftField['#url'] : '',
    text: studioCTALeftField ? studioCTALeftField['#title'] : '',
    type: 'primary',
    target: studioCTALeftField ? studioCTALeftField['#options']['attributes']['target'] : '',
    'aria-describedby': 'frontpage-ddb-studio',
  } %}

  {% set linkSecondary = {
    url: studioCTARightField ? studioCTARightField['#url'] : '',
    text: studioCTARightField ? studioCTARightField['#title'] : '',
    type: 'secondary',
    bg: 'dark',
    target: studioCTARightField ? studioCTARightField['#options']['attributes']['target'] : '',
    'aria-describedby': 'frontpage-ddb-studio',
  } %}
  <div class="ddb-studio">
    {% set studioImageField = content.field_studio_image[0]|default(null) %}
    {% if studioImageField and studioImageField.images %}
      {% set responsiveImage = { images: studioImageField.images } %}
      <div class="ddb-studio__background-image">
        {% include '@ddbp/partials/responsive-image.html.twig' with responsiveImage %}
      </div>
    {% endif %}
    <div class="container">
      <div class="row">
        <div class="column column--span-2">
          <p class="tiny-label">
            {{ 'DDBstudio' | t }}
          </p>
        </div>
        <div class="column column--span-10">
          <div class="ddb-studio__content">
            <h2 id="frontpage-ddb-studio">{{ content.field_studio_headline[0]['#context'].value|default('') }}</h2>
            <p class="h4">
              {{ content.field_studio_description[0]['#context'].value|default('') }}
            </p>
            <div class="ddb-studio__links links-siblings">
              {% if studioCTALeftField %}
                {% include '@ddbp/partials/link-button.html.twig' with { link: linkPrimary } %}
              {% endif %}
              {% if studioCTARightField %}
                {% include '@ddbp/partials/link-button.html.twig' with { link: linkSecondary } %}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# departments #}
  {% set departments = get_nodes('department') %}
  {% if departments|length %}
    <div class="departments">
      <div class="container">
        <div class="row">
          <div class="column column--span-5 column--content">
            <h2>{{ 'Fachstellen' | t }}</h2>
            <p class="h4">
              {{ 'Unsere Fachstellen unterstützen und beraten Sie von der ersten Kontaktaufnahme bis zur finalen Datenlieferung.' | t }}
            </p>
            <div class="departments__departments">
              {{ departments }}
            </div>
          </div>
          <div class="column column--image">
            <div class="departments__images">
              {{ departments }}
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  {# latest events #}
  {% set linkNews = {
    url: path('view.latest_events.latest_events'),
    text: 'Alle anzeigen' | t,
    type: 'primary',
    'aria-describedby': 'frontpage-events-and-dates',
  } %}

  {% if latestEvents|length %}
    <div class="container">
      <div class="latest-events">
        <div class="latest-events__title">
          <h2 id="frontpage-events-and-dates">{{ 'Termine & Veranstaltungen' | t }}</h2>
        </div>
        <div class="latest-events__all">
          {% include '@ddbp/partials/link-button.html.twig' with { link: linkNews } %}
        </div>
        <div class="latest-events__events">
          <div class="row">
            {% for event in latestEvents %}
              <div>
                {{ event }}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
