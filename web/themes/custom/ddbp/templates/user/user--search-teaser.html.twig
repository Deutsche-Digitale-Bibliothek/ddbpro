{% set classes = [
  'node',
  'node--user',
  'search-teaser',
] %}

{% set type = 'Ansprechpartner*innen' | t %}
{% set url = url('entity.user.canonical', { 'user': user.id })['#markup'] %}
{% set academicDegree = content.field_academic_degree[0]['#context'].value|default('') %}
{% set firstname = content.field_firstname[0]['#context'].value|default('') %}
{% set lastname = content.field_lastname[0]['#context'].value|default('') %}
{% set nameSuffix = content.field_name_suffix[0]['#context'].value|default('') %}
{% set jobTitle = content.field_job_title[0]['#context'].value|default('') %}

<article{{ attributes.addClass(classes).removeAttribute('role') }}>
  <div class="search-teaser__type">
    {{ type }}
  </div>
  <a href="{{ url }}" class="search-teaser__title">
    <h2 class="h4">
      {% if academicDegree %}
        {{ academicDegree }}
      {% endif %}
      {{ firstname ~ ' ' ~ lastname }}
      {% if nameSuffix %}
        {{ nameSuffix }}
      {% endif %}
    </h2>
  </a>
  <a href="{{ url }}" class="search-teaser__description text-formatted" tabindex="-1">
    {% if jobTitle %}
      {% set jobTitleText = jobTitle|striptags|trim %}
      <p>{{ jobTitleText|truncate(400, true, '...') }}</p>
    {% endif %}
  </a>
  <div class="search-teaser__link" tabindex="-1">
    <a href="{{ url }}">
      {{ url }}
    </a>
  </div>
</article>
