{% set email = user.mail.value %}
{% set phone = content.field_phone[0]['#context'].value|default('') %}
{% set academicDegree = content.field_academic_degree[0]['#context'].value|default('') %}
{% set firstname = content.field_firstname[0]['#context'].value|default('') %}
{% set lastname = content.field_lastname[0]['#context'].value|default('') %}
{% set nameSuffix = content.field_name_suffix[0]['#context'].value|default('') %}
{% set jobTitle = content.field_job_title[0]['#context'].value|default('') %}
{% set institution = content.field_institution[0]['#context'].value|default('') %}
{% set hasUserImage = content.field_user_image['#items']|default([])|length %}

{% set linkPrimary = {
  url: 'mailto:' ~ email,
  text: email,
  target: true,
  mail: true,
  type: 'primary',
} %}

{% set linkSecondary = {
  url: path('view.team.team'),
  text: 'Zur Übersicht' | t,
  type: 'secondary',
  bg: 'light',
} %}

<article{{ attributes.addClass('user') }}>
  <div class="container">
    {# Breadcrumbs block #}
    {{ drupal_block('system_breadcrumb_block', wrapper=false) }}
  </div>

  <div class="node__content">
    <div class="container">
      <a id="main-content" tabindex="-1" class="visually-hidden"></a>
      <div class="row-grid row-grid--fixed">
        <div class="row-grid__title">
          <div class="row-grid__title-content">
            <div class="user__name h1">
              {% if academicDegree %}
                {{ academicDegree }}
              {% endif %}
              {{ firstname }}</br>
              {{ lastname }}
              {% if nameSuffix %}
                {{ nameSuffix }}
              {% endif %}
            </div>

            {% if jobTitle %}
              <div class="user__job-title h4">
                {{ jobTitle }}
              </div>
            {% endif %}
          </div>
        </div>

        <div class="row-grid__sidebar">
          <div class="user__image">
            {% if hasUserImage %}
                {% set imageField = content.field_user_image[0]|default(null) %}
                {% if imageField and imageField.images %}
                  {% set responsiveImage = { images: imageField.images } %}
                  {% include '@ddbp/partials/responsive-image.html.twig' with responsiveImage %}
                {% else %}
                  <img src="/{{ directory }}/src/images/ddbp-platzhalter-team.webp" alt="">
                {% endif %}
            {% else %}
              <img src="/{{ directory }}/src/images/ddbp-platzhalter-team.webp" alt="">
            {% endif %}
          </div>
        </div>

        <div class="row-grid__content">
          <div class="row-grid__content-content">
            <div class="user__info">
              {% if institution %}
                <div class="user__info-institution">
                  {{ institution }}
                </div>
              {% endif %}
              <div class="user__info-address">
                {{ content.field_address }}
              </div>
              <div class="user__info-phone">
                {{ 'Tel.:' | t }}
                <a href="tel:{{ phone|replace({' ': ''}) }}" class="user__phone" target="_blank">
                  {{ phone }}
                </a>
              </div>
            </div>

            <div class="user__links links-siblings">
              {# email #}
              {% if email %}
                {% include '@ddbp/partials/link-button.html.twig' with { link: linkPrimary } %}
              {% endif %}
              {# link to overview #}
              {% include '@ddbp/partials/link-button.html.twig' with { link: linkSecondary } %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# stable link placeholder #}
  <div aria-hidden="true" class="stable-link__placeholder visually-hidden">{{ get_current_path() }}</div>
</article>
